<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.tools.com/tools"
    xmlns:tools2="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".KasirPasienActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="?attr/actionModeCloseDrawable"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#0F172A" />

        <TextView
            android:id="@+id/txtNamaRS"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Rumah Sakit Delta"
            android:textColor="#0F172A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnNotifikasi"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_notifikasi"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@android:color/holo_orange_light" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/layoutStepper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_cricle_blue"
                android:backgroundTint="#2563EB"
                android:gravity="center"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient"
                android:textSize="11sp"
                android:textColor="#2563EB"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="#CBD5E1"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_circle_gray"
                android:backgroundTint="#E2E8F0"
                android:gravity="center"
                android:text="2"
                android:textColor="#64748B" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Services"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="#CBD5E1"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_circle_gray"
                android:backgroundTint="#E2E8F0"
                android:gravity="center"
                android:text="3"
                android:textColor="#64748B" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/lblTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:text="Data Pasien"
        android:textColor="#0F172A"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/layoutStepper" />

    <TextView
        android:id="@+id/lblSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="4dp"
        android:text="Verifikasi detail pasien sebelum melanjutkan ke pemilihan layanan."
        android:textColor="#64748B"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/lblTitle" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardPasien"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/lblSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardFoto"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/imgFotoPasien"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/cardFoto"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtIdPasien"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PATIENT ID: RD-2024-B891"
                        android:textColor="#2563EB"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtNamaPasien"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Budi Santoso"
                        android:textColor="#0F172A"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>

                    <TextView
                        android:id="@+id/badgeStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@android:drawable/toast_frame"
                        android:backgroundTint="#DCFCE7"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="Status: Aktif"
                        android:textColor="#16A34A"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E2E8F0"
                android:layout_marginVertical="14dp"/>

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="1">

                <TableRow android:layout_marginBottom="10dp">
                    <TextView android:text="Tanggal Lahir" android:textColor="#64748B" android:textSize="13sp"/>
                    <TextView android:id="@+id/txtTglLahir" android:text="12 Mei 1985" android:textColor="#0F172A" android:textSize="13sp" android:gravity="end" android:textStyle="bold"/>
                </TableRow>
                <TableRow android:layout_marginBottom="10dp">
                    <TextView android:text="Jenis Kelamin" android:textColor="#64748B" android:textSize="13sp"/>
                    <TextView android:id="@+id/txtGender" android:text="Laki-laki" android:textColor="#0F172A" android:textSize="13sp" android:gravity="end" android:textStyle="bold"/>
                </TableRow>
                <TableRow android:layout_marginBottom="10dp">
                    <TextView android:text="No. Telepon" android:textColor="#64748B" android:textSize="13sp"/>
                    <TextView android:id="@+id/txtTelepon" android:text="+62 812 3456 7890" android:textColor="#0F172A" android:textSize="13sp" android:gravity="end" android:textStyle="bold"/>
                </TableRow>
                <TableRow>
                    <TextView android:text="Alamat" android:textColor="#64748B" android:textSize="13sp"/>
                    <TextView android:id="@+id/txtAlamat" android:text="Jl. Merdeka No. 45, Kebayoran Baru, Jakarta Selatan" android:textColor="#0F172A" android:textSize="13sp" android:gravity="end" android:maxWidth="200dp" android:textStyle="bold"/>
                </TableRow>
            </TableLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardAsuransi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#EFF6FF"
        app:layout_constraintTop_toBottomOf="@id/cardPasien">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <ImageView
                android:id="@+id/imgShield"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#2563EB"
                android:layout_centerVertical="true"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imgShield"
                android:layout_marginStart="12dp"
                android:orientation="vertical"
                android:layout_centerVertical="true">
                <TextView
                    android:id="@+id/txtJenisAsuransi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BPJS Kesehatan"
                    android:textColor="#0F172A"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Asuransi Terverifikasi"
                    android:textColor="#64748B"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/btnUbahAsuransi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Ubah"
                android:textColor="#2563EB"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="4dp"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardKonfirmasi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/cardAsuransi">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="top">

            <CheckBox
                android:id="@+id/cbValidasi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#2563EB"
                android:layout_marginTop="-4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data sudah sesuai"
                    android:textColor="#0F172A"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saya mengkonfirmasi bahwa informasi pasien di atas adalah benar."
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnSelanjutnya"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_margin="20dp"
        android:backgroundTint="#2563EB"
        android:text="Selanjutnya ›"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools2:layout_editor_absoluteX="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>